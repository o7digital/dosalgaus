# Variables d'environnement locales
# Copiez ce fichier en .env.local et remplissez vos valeurs

# WordPress/WooCommerce API
NEXT_PUBLIC_WORDPRESS_URL=https://oliviers55.sg-host.com
NEXT_PUBLIC_CHECKOUT_BASE_URL=https://oliviers55.sg-host.com
WC_CHECKOUT_BASE_URL=https://oliviers55.sg-host.com
WP_APP_USER=your_wordpress_application_user
WP_APP_PASSWORD=your_wordpress_application_password
WC_CONSUMER_KEY=your_woocommerce_consumer_key
WC_CONSUMER_SECRET=your_woocommerce_consumer_secret

# Next.js
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SHOW_UNDER_CONSTRUCTION=0
NEXT_PUBLIC_WP_PRICE_SOURCE_CURRENCY=USD
NEXT_PUBLIC_WP_DESCRIPTION_SOURCE_LANGUAGE=EN
NEXT_PUBLIC_WP_REFRESH_MS=30000
